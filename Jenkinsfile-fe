pipeline {
    agent any

    parameters {
        string(name: 'BRANCH_NAME', defaultValue: 'Accelerate-dev-v1', description: 'Branch to build')
        choice(name: 'DEPLOY_ENV', choices: ['dev'], description: 'Environment to deploy')
    }

    environment {
        AZURE_CREDENTIALS_ID = 'c72037f6-e5d5-46fd-9fa1-8ab164be7696'
        IMAGE_NAME = 'wen-accelerate-assisted-growth-fe'
    }

    stages {
        stage('Setup Environment') {
            steps {
                script {
                    // Only DEV environment
                    env.ACR_NAME = 'nextgendevelop'
                    env.ACR_LOGIN_SERVER = 'nextgendevelop.azurecr.io'
                    env.ENV = 'dev'
                    env.KUBE_CONFIG = 'Nextgen-dev-cluster'
                }
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                withCredentials([
                    azureServicePrincipal(credentialsId: "${env.AZURE_CREDENTIALS_ID}"),
                    string(credentialsId: 'npm_token_key', variable: 'NPM_TOKEN')
                ]) {
                    script {
                        try {
                            echo "Building Docker image: ${env.ACR_LOGIN_SERVER}/${env.IMAGE_NAME}:${env.ENV}-${env.BUILD_NUMBER}"
                            echo "⚠️  Building WITHOUT CACHE to fix corrupted layer issue"
                            dockerImage = docker.build(
                                "${env.ACR_LOGIN_SERVER}/${env.IMAGE_NAME}:${env.ENV}-${env.BUILD_NUMBER}",
                                "--no-cache ."
                            )
                            env.DOCKER_IMAGE_BUILT = 'true'
                        } catch (Exception e) {
                            env.DOCKER_IMAGE_BUILT = 'false'
                            echo "Docker build failed: ${e.getMessage()}"
                            throw e
                        }
                    }
                }
            }
        }

        stage('Login to ACR') {
            steps {
                withCredentials([azureServicePrincipal(credentialsId: "${env.AZURE_CREDENTIALS_ID}")]) {
                    script {
                        sh """
                        az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID
                        az acr login --name ${ACR_NAME}
                        """
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    dockerImage.push()
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([file(credentialsId: "${env.KUBE_CONFIG}", variable: 'KUBECONFIG')]) {
                    script {
                        sh """
                        kubectl --kubeconfig=\${KUBECONFIG} set image deployment/${env.IMAGE_NAME} ${env.IMAGE_NAME}=${env.ACR_LOGIN_SERVER}/${env.IMAGE_NAME}:${env.ENV}-${env.BUILD_NUMBER} --record
                        kubectl --kubeconfig=\${KUBECONFIG} rollout status deployment/${env.IMAGE_NAME}
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                if (env.DOCKER_IMAGE_BUILT == 'true') {
                    sh """
                        echo "Cleaning up Docker image: ${env.ACR_LOGIN_SERVER}/${env.IMAGE_NAME}:${env.ENV}-${env.BUILD_NUMBER}"
                        if docker images --format='{{.Repository}}:{{.Tag}}' | grep -q "${env.ACR_LOGIN_SERVER}/${env.IMAGE_NAME}:${env.ENV}-${env.BUILD_NUMBER}"; then
                            docker rmi ${env.ACR_LOGIN_SERVER}/${env.IMAGE_NAME}:${env.ENV}-${env.BUILD_NUMBER} || echo "Failed to remove image, but continuing..."
                        else
                            echo "Docker image not found in local registry, skipping removal"
                        fi
                    """
                } else {
                    echo "Docker image was not built successfully, skipping cleanup"
                }
            }
        }
        success {
            echo '✅ The Docker image has been successfully pushed and deployed to Kubernetes.'
        }
        failure {
            echo '❌ The build, push, or deployment process has failed.'
        }
    }
}